def run_pdflatex(tex_path):
    """Compile a generated LaTeX report.

    Args:
        tex_path: Path to the generated ``.tex`` file.

    Returns:
        Path to the expected PDF file.

    Raises:
        subprocess.CalledProcessError: If ``pdflatex`` returns a non-zero exit
            status.
        FileNotFoundError: If ``pdflatex`` is not available.
    """
    tex_dir = os.path.dirname(tex_path)
    tex_file = os.path.basename(tex_path)
    pdf_path = os.path.splitext(tex_path)[0] + '.pdf'
    command = ['pdflatex', '-interaction=nonstopmode', tex_file]
    print('running:', ' '.join(command), flush=True)
    subprocess.run(command, cwd=tex_dir, check=True)
    return pdf_path


def create_output_directory(input_name, directory, subdirectory, suffix):
    """Create an output directory and copy input artifacts into it.

    Args:
        input_name: Input ``.rxt`` filename, with or without the extension.
        directory: Optional explicit output directory name.
        subdirectory: Optional parent directory for per-input output folders.
        suffix: Suffix for the default output directory, such as ``'_notebook'``
            or ``'_pdf'``.

    Returns:
        A ``(base, base_path)`` tuple. Both values are empty strings when the
        input file cannot be used.
    """
    
    # ensure that file.rxt exists and support omitting .rxt
    if os.path.exists(input_name):
        if not os.path.isfile(input_name) or not input_name.endswith('.rxt'):
            return '', ''
    elif not input_name.endswith('.rxt'):
        input_name += '.rxt'
        if not os.path.exists(input_name):
            print('input file "%s" not found' % input_name)
            return '', ''
    else:
        print('input file "%s" not found' % input_name)
        return '', ''
    
    local_dir = os.path.dirname(input_name)

    # extract the 'name' from 'path/to/name.rxt'
    base = os.path.splitext(os.path.basename(input_name))[0]

    if subdirectory is None:
        if directory is None:
            # output directory will be in same directory as file_name
            output_dir = os.path.join(local_dir, base + suffix)
        else:
            output_dir = os.path.join(local_dir, directory)
            if os.path.exists(output_dir) and os.path.isfile(output_dir):
                print("Sorry, but '%s' is an existing file!" % output_dir)
                print("Use a new or existing directory with --dir option.")
                sys.exit()
    else:
        # output directory will be in subdir/file_name
            output_dir = os.path.join(subdirectory, base)

    if not os.path.exists(output_dir):
        os.makedirs(output_dir)

    # copy file.rxt to output directory
    shutil.copy(input_name, output_dir)

    # if file.txt exists, copy it to the output directory
    txt_name = os.path.join(local_dir, base + '.txt')
    output_txt_name = os.path.join(output_dir, base + '.txt')
    if os.path.exists(txt_name) and not os.path.exists(output_txt_name):
        shutil.copy(txt_name, output_dir)

    # if file.grid exists, copy it to the output directory
    grid_name = os.path.join(local_dir, base + '.grid')
    output_grid_name = os.path.join(output_dir, base + '.grid')
    if os.path.exists(grid_name) and not os.path.exists(output_grid_name):
        shutil.copy(grid_name, output_dir)

    # the base name for all created files
    base_path = os.path.join(output_dir, base)

    return base, base_path

def txt_matches_iad_command(txt_path, command_str):
    """Return whether an existing output file was made by a command.

    Args:
        txt_path: Path to an existing ``iad`` output file.
        command_str: Shell-quoted command string expected in the file header.

    Returns:
        True when the header contains ``command_str``.
    """
    if not os.path.exists(txt_path) or os.path.getsize(txt_path) == 0:
        return False

    with open(txt_path, 'r', encoding='utf-8') as file:
        for line in file:
            if not line.startswith('#'):
                break
            header_line = line[1:].strip()
            if header_line == command_str:
                return True

    return False

def split_iadplus_arguments(argv, parser):
    """Split wrapper arguments from short options that should pass to ``iad``.

    Args:
        argv: Raw command-line arguments, excluding the program name.
        parser: ``argparse`` parser used for user-facing errors.

    Returns:
        A tuple ``(iadplus_argv, iad_args, input_files)`` where ``iadplus_argv``
        contains options for this wrapper, ``iad_args`` contains arguments to
        pass to ``iad``, and ``input_files`` contains positional inputs.

    Raises:
        SystemExit: Via ``parser.error`` for unknown options, missing option
            values, or unsupported ``-z`` forwarding.
    """
    iadplus_argv = []
    iad_args = []
    input_files = []
    iadplus_options_with_values = {'--dir', '--sdir'}
    index = 0

    while index < len(argv):
        arg = argv[index]

        if arg == '--':
            input_files.extend(argv[index + 1:])
            break

        if arg == '-h' or arg == '--help':
            iadplus_argv.append(arg)
            index += 1
            continue

        if arg.startswith('--'):
            option_name = arg.split('=', 1)[0]
            if option_name in iadplus_options_with_values and '=' not in arg:
                index += 1
                if index >= len(argv):
                    parser.error('%s requires an argument' % arg)
                iadplus_argv.extend([arg, argv[index]])
            else:
                iadplus_argv.append(arg)
            index += 1
            continue

        if arg.startswith('-') and arg != '-':
            option_text = arg[1:]
            while option_text:
                option = option_text[0]
                remainder = option_text[1:]

                if option == 'z':
                    parser.error('iadplus does not support passing -z to iad')

                if option in IAD_OPTIONS_WITH_VALUES:
                    if remainder:
                        value = remainder[1:] if remainder.startswith('=') else remainder
                    else:
                        index += 1
                        if index >= len(argv):
                            parser.error('-%s requires an argument' % option)
                        value = argv[index]
                    iad_args.extend(['-' + option, value])
                    option_text = ''
                elif option in IAD_OPTIONS_WITHOUT_VALUES:
                    iad_args.append('-' + option)
                    option_text = remainder
                else:
                    parser.error('unknown iad option -%s' % option)
            index += 1
            continue

        input_files.append(arg)
        index += 1

    return iadplus_argv, iad_args, input_files

def main():
    """Run the ``iadplus`` command-line interface.

    Parses wrapper and forwarded ``iad`` options, creates output directories,
    runs ``iad`` when needed, generates plots, and writes PDF, notebook, or HTML
    reports for all requested input files.
    """
    desc = """Create a plotted report for one or more iad .rxt input files.

iadplus runs iad when needed, parses the generated .txt output, and writes a
PDF report by default.  Use --notebook or --html for those report formats.

Most valid short iad options may be passed directly to iadplus and are forwarded
to iad.  For example, "-M 0 -q 4" is forwarded to the iad command used for each
input file.

Output directories:
  By default, each input is written next to the .rxt file in a directory named
  INPUT_pdf, INPUT_notebook, or INPUT_html.
  --dir DIRECTORY writes a single input's report into that named directory.
  --sdir SUBDIRECTORY writes each input to SUBDIRECTORY/INPUT, which is useful
  for batch runs such as "iadplus --sdir reports *.rxt".

Examples:
  iadplus sample_A.rxt
  iadplus --html -M 0 -q 4 sample_A.rxt
  iadplus --notebook --force -i 8 -X docs/phantom_with_no_slides.rxt
  iadplus --fit -c 0 tests/rxt/1_sphere/ville1.rxt
"""
    parser = argparse.ArgumentParser(
        description=desc,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument('--dir',  metavar='DIRECTORY', default=None,
                        help='write output for one input into DIRECTORY')
    parser.add_argument('--sdir',  metavar='SUBDIRECTORY', default=None,
                        help='write each input to SUBDIRECTORY/INPUT; useful with *.rxt')
    parser.add_argument('--force', action='store_true',
                        help='Force reanalysis of files')
    parser.add_argument('--fit', action='store_true',
                        help='Fit scattering data to a*(λ/1000nm)**(-b)')
    output_group = parser.add_mutually_exclusive_group()
    output_group.add_argument('--pdf', dest='output_mode', action='store_const', const='pdf',
                              help='create a PDF report (default)')
    output_group.add_argument('--notebook', dest='output_mode', action='store_const',
                              const='notebook',
                              help='create a Jupyter notebook report')
    output_group.add_argument('--html', dest='output_mode', action='store_const', const='html',
                              help='create an HTML report')
    parser.set_defaults(output_mode='pdf')
    iadplus_argv, direct_iad_args, input_files = split_iadplus_arguments(sys.argv[1:], parser)
    args = parser.parse_args(iadplus_argv)
    args.input_files = input_files
    args.iad_args = direct_iad_args
    if not args.input_files:
        parser.error('at least one input file is required')
    iadplus_command = iadplus_command_line()

    # You can then iterate over this list to open and process each file
    outputs = []
    for file_name in args.input_files:

        suffix = '_' + args.output_mode
        figure_ext = '.pdf' if args.output_mode == 'pdf' else '.svg'

        base, base_path = create_output_directory(file_name, args.dir, args.sdir, suffix)
        if base_path == '':
            continue
        iad_command = iad_command_line(file_name, args.iad_args)

        artifact_base_path = base_path
        if args.output_mode == 'pdf':
            artifact_base = latex_artifact_name(base)
            artifact_base_path = os.path.join(os.path.dirname(base_path), artifact_base)

        # doing the iad analysis can be slow, avoid if possible
        txt_path = base_path + '.txt'
        command = [iad_executable()]
        command.extend(args.iad_args)
        command.append('-J')
        command.append(base_path + '.rxt')
        command_str = ' '.join(shlex.quote(item) for item in command)
        ran_iad = False
        current_output = txt_matches_iad_command(txt_path, command_str)
        if args.force or not current_output:
            print('running:', command_str)
            try:
                subprocess.run(command, shell=False, check=True)
                ran_iad = True
            except (FileNotFoundError, subprocess.CalledProcessError):
                print("Sorry, iad failed.  check header maybe?")
                continue
        else:
            print('Using existing %s' % txt_path)

        try:
            result = np.loadtxt(txt_path, skiprows=44, usecols=range(8), delimiter='\t')
        except ValueError:
            if ran_iad:
                raise
            print('Existing output could not be parsed, rerunning...')
            try:
                subprocess.run(command, shell=False, check=True)
            except (FileNotFoundError, subprocess.CalledProcessError):
                print("Sorry, iad failed.  check header maybe?")
                continue
            result = np.loadtxt(txt_path, skiprows=44, usecols=range(8), delimiter='\t')
        lam, mr, cr, mt, ct, mua, musp, g = result.T
        lam = np.atleast_1d(lam)
        mr = np.atleast_1d(mr)
        cr = np.atleast_1d(cr)
        mt = np.atleast_1d(mt)
        ct = np.atleast_1d(ct)
        mua = np.atleast_1d(mua)
        musp = np.atleast_1d(musp)
        g = np.atleast_1d(g)

        converters = {8: lambda s: s.lstrip('#').strip()}
        status = np.loadtxt(txt_path, usecols=[8], dtype=str, converters=converters)
        status = np.atleast_1d(status)
        success = status == '*'

        d = get_thickness(txt_path, base_path + '.rxt')
        mus = musp/(1-g)
        b = (mua + mus)*d

        denominator = mua + mus
        safe_denominator = np.where(denominator == 0, np.inf, denominator)
        a = mus / safe_denominator

        if (args.output_mode == 'pdf' and artifact_base_path != base_path
                and os.path.exists(base_path + '.grid')):
            shutil.copy(base_path + '.grid', artifact_base_path + '.grid')

        rt_graph = plot_rt(lam, mr, mt, artifact_base_path, figure_ext)
        r_graph = plot_r(lam, mr, cr, success, artifact_base_path, figure_ext)
        t_graph = plot_t(lam, mt, ct, success, artifact_base_path, figure_ext)
        mua_graph = plot_mua(lam, mua, success, artifact_base_path, figure_ext)
        musp_graph = plot_musp(lam, musp, success, artifact_base_path, figure_ext, fit=args.fit)
        mus_graph = plot_mus(lam, mus, success, artifact_base_path, figure_ext, fit=args.fit)
        a_graph = plot_a(lam, a, success, artifact_base_path, figure_ext)
        b_graph = plot_b(lam, b, success, artifact_base_path, figure_ext)
        g_graph = plot_g(lam, g, success, artifact_base_path, figure_ext)
        grid_graph = plot_grid(mr, cr, mt, ct, success, artifact_base_path, figure_ext)

        graph_groups = [
            [('', rt_graph)],
            [('Reflection', r_graph), ('Transmission', t_graph)],
            [('Scattering Coefficient', mus_graph),
             ('Reduced Scattering Coefficient', musp_graph)],
            [('Absorption Coefficient', mua_graph),
             ('Scattering Anisotropy', g_graph)],
            [('Single Scattering Albedo', a_graph), ('Optical Thickness', b_graph)],
            [('Grid Graph', grid_graph)],
        ]

        if args.output_mode == 'pdf':
            tex_path = artifact_base_path + '.tex'
            write_latex_report(tex_path, base_path + '.rxt', txt_path, graph_groups,
                               iadplus_command, iad_command)
            try:
                outputs.append(run_pdflatex(tex_path))
            except (FileNotFoundError, subprocess.CalledProcessError):
                print("Sorry, pdflatex failed for %s" % tex_path)
                continue
        elif args.output_mode == 'notebook':
            nb = create_report_notebook(base_path + '.rxt', txt_path, graph_groups,
                                        iadplus_command, iad_command)
            ipynb_path = base_path + '.ipynb'
            with open(ipynb_path, "w", encoding="utf-8") as f:
                nbformat.write(nb, f)

            outputs.append(ipynb_path)
        else:
            html_path = base_path + '.html'
            write_html_report(html_path, base_path + '.rxt', txt_path, graph_groups,
                              iadplus_command, iad_command)
            outputs.append(html_path)

    for output in outputs:
        print('created: ' + os.path.abspath(output))


if __name__ == "__main__":
    main()
