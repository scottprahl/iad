# Define the function you want to fit
def scattering_model(x, a, b):
    """Evaluate the scattering power-law model.

    Args:
        x: Wavelength values in nanometers.
        a: Power-law amplitude.
        b: Power-law exponent.

    Returns:
        Modeled scattering values ``a * (x / 1000) ** (-b)``.
    """
    return a * (x / 1000) ** (-b)

def add_scattering_fit(lam, values, success, label):
    """Add a power-law scattering fit to the current plot when possible.

    Args:
        lam: Wavelength or measurement-number coordinates.
        values: Scattering values to fit.
        success: Boolean mask selecting successful rows.
        label: Name to use in the plotted fit label.

    Returns:
        True when a fit was added, otherwise false.
    """
    if lam[0] <= 300 or np.count_nonzero(success) < 2:
        return False

    popt, _ = curve_fit(scattering_model, lam[success], values[success])
    a_opt, b_opt = popt
    lamb = np.linspace(min(lam), max(lam))
    fn_str = "%s=%g * (lambda_nm/1000)**(-%g)" % (label, a_opt, b_opt)
    plt.plot(lamb, scattering_model(lamb, a_opt, b_opt), label=fn_str)
    plt.legend()
    return True

