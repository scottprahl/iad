def _numbers_in_row(line):
    """Return numeric values before any inline comment.

    Args:
        line: Input line from an ``.rxt`` file.

    Returns:
        List of floating-point values, or an empty list when a token is not
        numeric.
    """
    line = line.split('#', 1)[0]
    values = []
    for token in line.split():
        try:
            values.append(float(token))
        except ValueError:
            return []
    return values


def _read_rxt_column(input_filename, label):
    """Read a labeled numeric column from an ``iad`` ``.rxt`` file.

    Args:
        input_filename: Path to the ``.rxt`` file.
        label: Lowercase column label to find.

    Returns:
        NumPy array containing the column values.

    Raises:
        ValueError: If the label or any values cannot be found.
    """
    label_index = None
    values = []

    with open(input_filename, 'r', encoding='utf-8') as file:
        for line in file:
            stripped = line.strip()
            if not stripped:
                continue

            if label_index is None:
                candidate = stripped.lstrip('#').split('#', 1)[0].split()
                labels = [item.lower() for item in candidate]
                if label in labels:
                    label_index = labels.index(label)
                continue

            row = _numbers_in_row(stripped)
            if row and len(row) > label_index:
                values.append(row[label_index])

    if label_index is None or not values:
        raise ValueError('Could not find column "%s" in %s' % (label, input_filename))

    return np.asarray(values)


def get_thickness(output_filename, input_filename=None):
    """Return sample thickness from an output header or input rows.

    Args:
        output_filename: Path to the generated ``.txt`` output file.
        input_filename: Optional path to the source ``.rxt`` file. Used when the
            output header says thickness varies by input row.

    Returns:
        Scalar thickness value, or an array of row-specific values when the
        source file contains a thickness column.

    Raises:
        ValueError: If thickness cannot be determined.
    """
    pattern = r'Sample thickness\s*=\s*([-+]?(?:\d+\.?\d*|\.\d+)(?:[eE][-+]?\d+)?)'
    with open(output_filename, 'r', encoding='utf-8') as file:
        for line in file:
            match = re.search(pattern, line)
            if match:
                return float(match.group(1))
            if 'Sample thickness' in line and 'varies with input row' in line:
                if input_filename is None:
                    input_filename = os.path.splitext(output_filename)[0] + '.rxt'
                return _read_rxt_column(input_filename, 'd')

    raise ValueError('Could not determine sample thickness from %s' % output_filename)


