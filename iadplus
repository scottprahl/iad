def write_verbatim_file(file, filename, replace_tabs=False):
    """Embed a text file in a LaTeX Verbatim environment."""
    file.write(r'\begin{Verbatim}[fontsize=\small]' + '\n')
    with open(filename, 'r', encoding='utf-8') as input_file:
        for line in input_file:
            if replace_tabs:
                line = line.replace('\t', ' ')
            file.write(line)
    file.write(r'\end{Verbatim}' + '\n\n')


def write_latex_graph_group(file, graph_group):
    """Write a group of one or more graph sections to LaTeX."""
    max_height = r'0.78\textheight' if len(graph_group) == 1 else r'0.42\textheight'
    for header, graph in graph_group:
        if header:
            file.write(r'\section*{%s}' % latex_escape(header) + '\n')
            if header == 'Grid Graph':
                file.write(GRID_EXPLANATION+ '\n\n')
        file.write(r'\begin{figure}[H]' + '\n')
        file.write(r'\centering' + '\n')
        file.write(r'\includegraphics[width=\linewidth,height=%s,keepaspectratio]{%s}' %
                   (max_height, latex_path(graph)) + '\n')
        file.write(r'\end{figure}' + '\n\n')


