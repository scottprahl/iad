def active_polygon():
    """Create the active measurement-region polygon.

    Returns:
        A Matplotlib ``Polygon`` representing the triangular
        reflection/transmission measurement domain.
    """
    xy = np.array([[1,0], [0,1], [0,0]])
    return plt.Polygon(xy, closed=True, facecolor='b', alpha=0.2)

def add_x_label(lambda0):
    """Label the current plot's x axis from the first coordinate value.

    Args:
        lambda0: Array-like wavelength or measurement-number coordinates. Values
            above 300 are treated as wavelengths in nanometers.
    """
    if lambda0[0] > 300:
        plt.xlabel('Wavelength (nm)', fontsize=axis_label_size)
    else:
        plt.xlabel('Measurement Number', fontsize=axis_label_size)

def plot_good(x, y, success, big_points=False):
    """Plot successful fit points on the current axes.

    Args:
        x: Array-like x coordinates.
        y: Array-like y coordinates.
        success: Boolean mask selecting successful rows.
        big_points: When true, draw larger hollow markers for overlays.
    """
    if big_points:
        size = 7
        fc = 'none'
    else :
        size = 2
        fc = 'blue'
    if any(success):
        plt.plot(x[success], y[success], marker='o', markersize=size,
                 markerfacecolor=fc, markeredgecolor='blue', linestyle='None',
                 label='fit')
    plt.grid(True)

def plot_good_and_bad(x, y, success, big_points=False):
    """Plot successful and failed fit points on the current axes.

    Args:
        x: Array-like x coordinates.
        y: Array-like y coordinates.
        success: Boolean mask selecting successful rows.
        big_points: When true, draw larger hollow markers for successful rows.
    """
    if big_points:
        size = 7
        fc = 'none'
    else :
        size = 2
        fc = 'blue'
    if any(success):
        plt.plot(x[success], y[success], marker='o', markersize=size,
                 markerfacecolor=fc, markeredgecolor='blue', linestyle='None',
                 label='fit')

    if any(~success):
        plt.plot(x[~success], y[~success], 'xr', label='failed')
        plt.legend()
    plt.grid(True)

def plot_gridlines(filename_base):
    """Draw grid contours from an ``iad`` ``.grid`` file.

    Args:
        filename_base: Output filename without extension. The function reads
            ``filename_base + '.grid'`` when it exists.
    """
    gridname = filename_base + '.grid'

    if not os.path.exists(gridname) or os.path.getsize(gridname) == 0:
        print('no grid file "%s"' % gridname)
        return

    a,b,g,mr,mt = np.loadtxt(gridname, skiprows=2, delimiter=',').T

    with open(gridname, 'r') as file:
        cmd = file.readline()
    cmd = cmd[2:]
    cmd = cmd.replace('-J ', '')
    match = re.search(r"g=([0-9.]+)", cmd)
    g_value = float(match.group(1)) if match else None

    N = len(a)

    a_list = list(set(a))
    for aa in a_list:
        r = [mr[i] for i in range(N) if a[i] == aa]
        t = [mt[i] for i in range(N) if a[i] == aa]
        plt.plot(r, t, 'k', lw=0.5)
        if aa==0:
            plt.text(r[-1],t[-1]-0.01, "a'=%4.2f" % aa, ha='center', va='top')
        else:
            plt.text(r[-1],t[-1]-0.01, '%4.2f' % aa, ha='center', va='top')

    b_list = list(set(b))
    for bb in b_list:
        r = [mr[i] for i in range(N) if b[i] == bb]
        t = [mt[i] for i in range(N) if b[i] == bb]
        plt.plot(r, t, 'k', lw=0.5)
        plt.text(r[-1],t[-1], "b'=%g" % bb)

    r = [mr[i] for i in range(N) if a[i] == 1]
    t = [mt[i] for i in range(N) if a[i] == 1]
    r1 = [mr[i] for i in range(N) if b[i] == 100]
    t1 = [mt[i] for i in range(N) if b[i] == 100]
    r2 = [mr[i] for i in range(N) if a[i] == 0]
    t2 = [mt[i] for i in range(N) if a[i] == 0]
    r = r + r1[::-1] + r2[::-1]
    t = t + t1[::-1] + t2[::-1]
    rt = np.array([r,t]).T
    poly = plt.Polygon(rt, closed=True, facecolor=skyblue, edgecolor='none')
    plt.gca().add_patch(poly)
    
    plt.plot(r, t, 'k', lw=0.5)
    plt.title(os.path.basename(filename_base) + ".rxt (assuming g=%.3f)" % g_value)
    plt.grid(False)

def plot_grid(mr, cr, mt, ct, success, filename_base, figure_ext):
    """Create the reflection/transmission grid plot.

    Args:
        mr: Measured reflectance values.
        cr: Calculated reflectance fit values.
        mt: Measured transmittance values.
        ct: Calculated transmittance fit values.
        success: Boolean mask selecting successful rows.
        filename_base: Output filename without extension.
        figure_ext: Figure extension, such as ``'.svg'`` or ``'.pdf'``.

    Returns:
        Basename of the saved figure.
    """
    out_filename = filename_base + '-grid' + figure_ext
    plt.figure(figsize=(8,8))
    plt.gca().set_aspect(1)
    plt.xlim(-0.05,1.05)
    plt.ylim(-0.05,1.05)
    plt.xticks(fontsize=12)
    plt.yticks(fontsize=12)
    plot_good(cr, ct, success, True)
    plt.plot(mr[success], mt[success], 'o', markersize=2, color=azure, label='measured')
    if any(~success):
        plt.plot(mr[~success], mt[~success], 'x', markersize=5, color='red', label='failed')
    poly = plt.Polygon([[0,0],[0,1],[1,0]], closed=True, facecolor=yellow, edgecolor='none', alpha=1)
    plt.gca().add_patch(poly)
    plot_gridlines(filename_base)
    plt.xlabel('$M_R$ (Normalized Reflectance)',fontsize=axis_label_size)
    plt.ylabel('$M_T$ (Normalized Transmittance)',fontsize=axis_label_size)
    plt.legend()
    plt.savefig(out_filename, dpi=300)
    plt.close()
    return os.path.basename(out_filename)

