def run_pdflatex(tex_path):
    """Compile a generated LaTeX report and return the PDF path."""
    tex_dir = os.path.dirname(tex_path)
    tex_file = os.path.basename(tex_path)
    pdf_path = os.path.splitext(tex_path)[0] + '.pdf'
    command = ['pdflatex', '-interaction=nonstopmode', tex_file]
    print('running:', ' '.join(command), flush=True)
    subprocess.run(command, cwd=tex_dir, check=True)
    return pdf_path


def create_output_directory(input_name, directory, subdirectory, suffix):
    """Create an output directory and copy the .rxt file into it."""
    
    # ensure that file.rxt exists and support omitting .rxt
    if os.path.exists(input_name):
        if not os.path.isfile(input_name) or not input_name.endswith('.rxt'):
            return '', ''
    elif not input_name.endswith('.rxt'):
        input_name += '.rxt'
        if not os.path.exists(input_name):
            print('input file "%s" not found' % input_name)
            return '', ''
    else:
        print('input file "%s" not found' % input_name)
        return '', ''
    
    local_dir = os.path.dirname(input_name)

    # extract the 'name' from 'path/to/name.rxt'
    base = os.path.splitext(os.path.basename(input_name))[0]

    if subdirectory is None:
        if directory is None:
            # output directory will be in same directory as file_name
            output_dir = os.path.join(local_dir, base + suffix)
        else:
            output_dir = os.path.join(local_dir, directory)
            if os.path.exists(output_dir) and os.path.isfile(output_dir):
                print("Sorry, but '%s' is an existing file!" % output_dir)
                print("Use a new or existing directory with --dir option.")
                sys.exit()
    else:
        # output directory will be in subdir/file_name
            output_dir = os.path.join(subdirectory, base)

    if not os.path.exists(output_dir):
        os.makedirs(output_dir)

    # copy file.rxt to output directory
    shutil.copy(input_name, output_dir)

    # if file.txt exists, copy it to the output directory
    txt_name = os.path.join(local_dir, base + '.txt')
    if os.path.exists(txt_name):
        shutil.copy(txt_name, output_dir)

    # if file.grid exists, copy it to the output directory
    grid_name = os.path.join(local_dir, base + '.grid')
    if os.path.exists(grid_name):
        shutil.copy(grid_name, output_dir)

    # the base name for all created files
    base_path = os.path.join(output_dir, base)

    return base, base_path

def main():
    desc =  'A wrapper for the iad program that creates a Jupyter notebook with plots '
    desc += 'of the input, the fitted results, and the derived optical properties.'
    parser = argparse.ArgumentParser(description=desc)
    parser.add_argument('input_files', nargs='+', help='List of .rxt files to process')
    parser.add_argument('--options', metavar='OPTIONS', type=str, nargs='?',
                        help='options to pass to iad program, e.g., "-c 0"')
    parser.add_argument('--dir',  metavar='DIRECTORY', default=None,
                        help='explicit name of directory to store notebook and files')
    parser.add_argument('--sdir',  metavar='SUBDIRECTORY', default=None,
                        help='use dir/file/ to store store notebook and files')
    parser.add_argument('--force', action='store_true',
                        help='Force reanalysis of files')
    parser.add_argument('--fit', action='store_true',
                        help='Fit scattering data to a*(λ/1000nm)**(-b)')
    parser.add_argument('--pdf', action='store_true',
                        help='Create LaTeX source and PDF-ready figures instead of a notebook')
    args = parser.parse_args()
    iadplus_command = iadplus_command_line()

    # You can then iterate over this list to open and process each file
    outputs = []
    for file_name in args.input_files:

        suffix = '_pdf' if args.pdf else '_notebook'
        figure_ext = '.pdf' if args.pdf else '.svg'

        base, base_path = create_output_directory(file_name, args.dir, args.sdir, suffix)
        if base_path == '':
            continue
        iad_command = iad_command_line(file_name, args.options)

        artifact_base_path = base_path
        if args.pdf:
            artifact_base = latex_artifact_name(base)
            artifact_base_path = os.path.join(os.path.dirname(base_path), artifact_base)

        # doing the iad analysis can be slow, avoid if possible
        txt_path = base_path + '.txt'
        exists_and_is_non_zero = os.path.exists(txt_path) and os.path.getsize(txt_path) > 0
        if args.force or not exists_and_is_non_zero:
            command = ['iad']
            if args.options:
                command.extend(shlex.split(args.options))
            command.append('-J')
            command.extend([shlex.quote(base_path+'.rxt')])
            command_str = ' '.join(command)
            print('running:', command_str)
            try:
                subprocess.run(command, shell=False, check=True)
            except subprocess.CalledProcessError:
                print("Sorry, iad failed.  check header maybe?")
                continue
        else:
            print('Skipping...')

        result = np.loadtxt(txt_path, skiprows=44, usecols=range(8), delimiter='\t')
        lam, mr, cr, mt, ct, mua, musp, g = result.T
        lam = np.atleast_1d(lam)
        mr = np.atleast_1d(mr)
        cr = np.atleast_1d(cr)
        mt = np.atleast_1d(mt)
        ct = np.atleast_1d(ct)
        mua = np.atleast_1d(mua)
        musp = np.atleast_1d(musp)
        g = np.atleast_1d(g)

        converters = {8: lambda s: s.lstrip('#').strip()}
        status = np.loadtxt(txt_path, usecols=[8], dtype=str, converters=converters)
        status = np.atleast_1d(status)
        success = status == '*'

        d = get_thickness(txt_path, base_path + '.rxt')
        mus = musp/(1-g)
        b = (mua + mus)*d

        denominator = mua + mus
        safe_denominator = np.where(denominator == 0, np.inf, denominator)
        a = mus / safe_denominator

        if args.pdf and artifact_base_path != base_path and os.path.exists(base_path + '.grid'):
            shutil.copy(base_path + '.grid', artifact_base_path + '.grid')

        rt_graph = plot_rt(lam, mr, mt, artifact_base_path, figure_ext)
        r_graph = plot_r(lam, mr, cr, success, artifact_base_path, figure_ext)
        t_graph = plot_t(lam, mt, ct, success, artifact_base_path, figure_ext)
        mua_graph = plot_mua(lam, mua, success, artifact_base_path, figure_ext)
        musp_graph = plot_musp(lam, musp, success, artifact_base_path, figure_ext, fit=args.fit)
        mus_graph = plot_mus(lam, mus, success, artifact_base_path, figure_ext, fit=args.fit)
        a_graph = plot_a(lam, a, success, artifact_base_path, figure_ext)
        b_graph = plot_b(lam, b, success, artifact_base_path, figure_ext)
        g_graph = plot_g(lam, g, success, artifact_base_path, figure_ext)
        grid_graph = plot_grid(mr, cr, mt, ct, success, artifact_base_path, figure_ext)

        graph_groups = [
            [('', rt_graph)],
            [('Reflection', r_graph), ('Transmission', t_graph)],
            [('Scattering Coefficient', mus_graph),
             ('Reduced Scattering Coefficient', musp_graph)],
            [('Absorption Coefficient', mua_graph),
             ('Scattering Anisotropy', g_graph)],
            [('Single Scattering Albedo', a_graph), ('Optical Thickness', b_graph)],
            [('Grid Graph', grid_graph)],
        ]

        if args.pdf:
            tex_path = artifact_base_path + '.tex'
            write_latex_report(tex_path, base_path + '.rxt', txt_path, graph_groups,
                               iadplus_command, iad_command)
            try:
                outputs.append(run_pdflatex(tex_path))
            except (FileNotFoundError, subprocess.CalledProcessError):
                print("Sorry, pdflatex failed for %s" % tex_path)
                continue
        else:
            nb = new_notebook()
            nb.metadata['kernelspec'] = {
                'display_name': 'Python 3',
                'language': 'python',
                'name': 'python3'
            }

            append_header(nb, base_path + '.rxt', txt_path, iadplus_command, iad_command)
            for header, graph in graph_groups[0]:
                append_graph_cell(nb, '## ' + header, graph)

            nb.cells.append(new_markdown_cell(markdown_header_table(txt_path)))

            for graph_group in graph_groups[1:]:
                for header, graph in graph_group:
                    append_graph_cell(nb, '## ' + header, graph)

            nb.cells.append(new_markdown_cell("## Input file\n"))
            append_file_cell(nb, '# input file', base + '.rxt')

            nb.cells.append(new_markdown_cell("## Output file\n"))
            append_file_cell(nb, '# output file', base + '.txt')

            # Save the notebook
            ipynb_path = base_path + '.ipynb'
            with open(ipynb_path, "w", encoding="utf-8") as f:
                nbformat.write(nb, f)

            outputs.append(ipynb_path)

    for output in outputs:
        print('created: ' + os.path.abspath(output))


if __name__ == "__main__":
    main()
