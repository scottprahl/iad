def append_graph_cell(nb, header, graph):
    """Append a Markdown image cell to a notebook.

    Args:
        nb: Notebook object to mutate.
        header: Markdown header text to prepend. The grid graph header also
            inserts the grid explanation.
        graph: Figure filename relative to the notebook.
    """
    cell_text = ''
    if header and header.strip('# '):
        cell_text = header + "\n"
        if header.strip('# ') == 'Grid Graph':
            cell_text += "\n" + GRID_EXPLANATION + "\n\n"
    url_encoded_filename = urllib.parse.quote(graph)
    cell_text += "<center>\n"
    cell_text += '    <img src="' + url_encoded_filename + '" width="80%" />\n'
    cell_text += "</center>\n"
    nb.cells.append(new_markdown_cell(cell_text))


def append_file_cell(nb, header, file):
    """Append a code cell that prints a sibling text file.

    Args:
        nb: Notebook object to mutate.
        header: Markdown-style comment header for the code cell.
        file: Path to the file whose basename should be opened by the notebook.
    """
    base = os.path.basename(file)
    cell_text = header + '\n'
    cell_text += 'with open(%r, "r", encoding="utf-8") as file:\n' % base
    cell_text += '    file_contents = file.read()\n'
    cell_text += '\n'
    cell_text += 'print(file_contents)\n'
    nb.cells.append(new_code_cell(cell_text))


def create_report_notebook(input_filename, output_filename, graph_groups, iadplus_command,
                           iad_command):
    """Create the notebook report object for one ``iad`` analysis.

    Args:
        input_filename: Path to the copied ``.rxt`` input file.
        output_filename: Path to the generated ``.txt`` output file.
        graph_groups: Ordered graph groups used to lay out the report.
        iadplus_command: Shell command used to invoke this wrapper.
        iad_command: Shell command used to invoke ``iad``.

    Returns:
        A populated notebook object.
    """
    nb = new_notebook()
    nb.metadata['kernelspec'] = {
        'display_name': 'Python 3',
        'language': 'python',
        'name': 'python3'
    }

    append_header(nb, input_filename, output_filename, iadplus_command, iad_command)
    for header, graph in graph_groups[0]:
        append_graph_cell(nb, '## ' + header, graph)

    nb.cells.append(new_markdown_cell(markdown_header_table(output_filename)))

    for graph_group in graph_groups[1:]:
        for header, graph in graph_group:
            append_graph_cell(nb, '## ' + header, graph)

    nb.cells.append(new_markdown_cell("## Input file\n"))
    append_file_cell(nb, '# input file', os.path.basename(input_filename))

    nb.cells.append(new_markdown_cell("## Output file\n"))
    append_file_cell(nb, '# output file', os.path.basename(output_filename))
    return nb


def normalize_output_header_value(value):
    """Normalize values from a generated ``.txt`` header field.

    Args:
        value: Raw value text read after ``=`` in an ``iad`` output header.

    Returns:
        Normalized value text suitable for table display.
    """
    value = value.strip()
    value = value.replace('(varies with input row)', 'varies')
    value = value.replace('varies with input row', 'varies')
    return value


def split_output_header_value(value):
    """Split a header value into displayed value and units text.

    Args:
        value: Raw or normalized header value.

    Returns:
        A ``(number, units)`` tuple. Either element may be an empty string.
    """
    value = normalize_output_header_value(value)
    if not value:
        return '', ''

    match = re.match(r'(\S+)(?:\s+(.*))?$', value)
    if not match:
        return value, ''

    number = match.group(1)
    units = (match.group(2) or '').strip()
    return number, units


def format_output_header_description(description, units):
    """Append units from a value field to a table description.

    Args:
        description: Header description text.
        units: Units or notes parsed from the value field.

    Returns:
        Description text with units in square brackets when units are present.
    """
    if not units:
        return description

    note = ''
    match = re.match(r'(.+?)\s+(\(.*\))$', units)
    if match:
        units = match.group(1).strip()
        note = ' ' + match.group(2).strip()

    return '%s [%s]%s' % (description, units, note)


def parse_output_header(output_filename):
    """Parse an ``iad`` output header through the photons-used line.

    Args:
        output_filename: Path to the generated ``.txt`` output file.

    Returns:
        List of ``(value, description)`` rows for report tables.
    """
    table_rows = []

    with open(output_filename, 'r', encoding='utf-8') as file:
        for line_number, line in enumerate(file, start=1):
            if line_number <= 2:
                continue

            text = line.lstrip('#').strip()
            if not text:
                continue

            if '=' in text:
                description, value = text.split('=', 1)
                description = description.strip()
                value, units = split_output_header_value(value)
                description = format_output_header_description(description, units)
                table_rows.append((value, description))

                if description.startswith('Photons used'):
                    break
            else:
                table_rows.append(('', text))

    return table_rows


def markdown_escape(text):
    """Escape text for a Markdown table cell.

    Args:
        text: Cell text to escape.

    Returns:
        Text with Markdown table metacharacters escaped.
    """
    return text.replace('\\', '\\\\').replace('|', '\\|')


def markdown_header_table(output_filename):
    """Build a Markdown table for an ``iad`` output header.

    Args:
        output_filename: Path to the generated ``.txt`` output file.

    Returns:
        Markdown table text, or an empty string when no rows are found.
    """
    table_rows = parse_output_header(output_filename)
    lines = []

    if table_rows:
        lines.append('| Number | Description |')
        lines.append('| --- | --- |')
        for value, description in table_rows:
            lines.append('| %s | %s |' %
                         (markdown_escape(value), markdown_escape(description)))
        lines.append('')

    return '\n'.join(lines)


def html_escape(text):
    """Escape text for HTML content.

    Args:
        text: Text to escape.

    Returns:
        HTML-escaped text.
    """
    return html.escape(str(text), quote=True)


def html_citations():
    """Return the citation section as HTML.

    Returns:
        HTML ordered list of citations with linked URLs.
