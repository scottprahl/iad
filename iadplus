        input_name: Input filename as supplied or resolved by the caller.

    Returns:
        Relative path when the absolute path is under the current directory,
        otherwise the original path.
    """
    if os.path.isabs(input_name):
        try:
            return os.path.relpath(input_name, os.getcwd())
        except ValueError:
            return input_name
    return input_name


def iad_command_line(input_name, iad_args):
    """Return the user-facing ``iad`` command used for an input file.

    Args:
        input_name: Input ``.rxt`` filename, with or without the extension.
        iad_args: Arguments that will be passed through to ``iad``.

    Returns:
        Shell-quoted command string suitable for report provenance.
    """
    display_name = input_name
    if not os.path.exists(display_name) and not display_name.endswith('.rxt'):
        display_name += '.rxt'

    command = ['./iad']
    command.extend(iad_args)
    command.extend(['-J', display_input_path(display_name)])
    return ' '.join(shlex.quote(arg) for arg in command)


