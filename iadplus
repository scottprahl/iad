def latex_escape(text):
    """Escape text for normal LaTeX paragraphs.

    Args:
        text: Plain text that may contain LaTeX metacharacters.

    Returns:
        Text with LaTeX metacharacters escaped.
    """
    replacements = {
        '\\': r'\textbackslash{}',
        '&': r'\&',
        '%': r'\%',
        '$': r'\$',
        '#': r'\#',
        '_': r'\_',
        '{': r'\{',
        '}': r'\}',
        '~': r'\textasciitilde{}',
        '^': r'\textasciicircum{}',
    }
    return ''.join(replacements.get(char, char) for char in text)


def latex_grid_explanation():
