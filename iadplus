def normalize_output_header_value(value):
    """Normalize values from the generated .txt header."""
    value = value.strip()
    value = value.replace('(varies with input row)', 'varies')
    value = value.replace('varies with input row', 'varies')
    return value


def split_output_header_value(value):
    """Return the table value and any units or notes from a header value."""
    value = normalize_output_header_value(value)
    if not value:
        return '', ''

    match = re.match(r'(\S+)(?:\s+(.*))?$', value)
    if not match:
        return value, ''

    number = match.group(1)
    units = (match.group(2) or '').strip()
    return number, units


def format_output_header_description(description, units):
    """Append units from the value field to the output header description."""
    if not units:
        return description

    note = ''
    match = re.match(r'(.+?)\s+(\(.*\))$', units)
    if match:
        units = match.group(1).strip()
        note = ' ' + match.group(2).strip()

    return '%s [%s]%s' % (description, units, note)


def parse_output_header(output_filename):
    """Parse the generated .txt header through the photons-used line."""
    table_rows = []

    with open(output_filename, 'r', encoding='utf-8') as file:
        for line_number, line in enumerate(file, start=1):
            if line_number <= 2:
                continue

            text = line.lstrip('#').strip()
            if not text:
                continue

            if '=' in text:
                description, value = text.split('=', 1)
                description = description.strip()
                value, units = split_output_header_value(value)
                description = format_output_header_description(description, units)
                table_rows.append((value, description))

                if description.startswith('Photons used'):
                    break
            else:
                table_rows.append(('', text))

    return table_rows


def markdown_escape(text):
    """Escape text for a Markdown table cell."""
    return text.replace('\\', '\\\\').replace('|', '\\|')


def markdown_header_table(output_filename):
    """Return Markdown for the generated output header summary."""
    table_rows = parse_output_header(output_filename)
    lines = []

    if table_rows:
        lines.append('| Number | Description |')
        lines.append('| --- | --- |')
        for value, description in table_rows:
            lines.append('| %s | %s |' %
                         (markdown_escape(value), markdown_escape(description)))
        lines.append('')

    return '\n'.join(lines)


def latex_escape(text):
    """Escape text for normal LaTeX paragraphs."""
    replacements = {
        '\\': r'\textbackslash{}',
        '&': r'\&',
        '%': r'\%',
        '$': r'\$',
        '#': r'\#',
        '_': r'\_',
        '{': r'\{',
        '}': r'\}',
        '~': r'\textasciitilde{}',
        '^': r'\textasciicircum{}',
    }
    return ''.join(replacements.get(char, char) for char in text)


def latex_grid_explanation():
    """Return the grid explanation with optical-property symbols in math mode."""
    text = latex_escape(GRID_EXPLANATION)
    text = text.replace("a'", r"$a'$")
    text = text.replace("b'", r"$b'$")
    text = text.replace("M_R", r"$M_R$")
    text = text.replace("M_T'", r"$M_T$")
    text = text.replace('anisotropy g,', r'anisotropy $g$,')
    return text


def latex_path(filename):
    """Return a LaTeX-safe path argument."""
    return r'\detokenize{%s}' % filename


def latex_artifact_name(name):
    """Return a filename stem that pdflatex can safely open."""
    safe = name.replace('%', 'pct')
    safe = re.sub(r'[^A-Za-z0-9_.-]+', '_', safe)
    return safe.strip('._') or 'iadplus_report'


def get_github_base_url():
    """Return the GitHub repository URL for this checkout."""
    try:
        result = subprocess.run(['git', 'remote', 'get-url', 'origin'],
                                check=True, capture_output=True, text=True)
    except (FileNotFoundError, subprocess.CalledProcessError):
        return 'https://github.com/scottprahl/iad'

    url = result.stdout.strip()
    match = re.match(r'git@github\.com:(.+?)(?:\.git)?$', url)
    if match:
        return 'https://github.com/' + match.group(1)

    match = re.match(r'https://github\.com/(.+?)(?:\.git)?$', url)
    if match:
        return 'https://github.com/' + match.group(1)

    return 'https://github.com/scottprahl/iad'


def version_to_tag(version):
    """Convert iad's printed version string to the release tag form."""
    return 'v' + version.replace('-', '.')


def git_tag_exists(tag):
    """Return True when a release tag exists in the local checkout."""
    try:
        subprocess.run(['git', 'rev-parse', '--verify', '--quiet', 'refs/tags/' + tag],
                       check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except (FileNotFoundError, subprocess.CalledProcessError):
        return False


def git_head_commit():
    """Return the current git commit hash, or an empty string if unavailable."""
    try:
        result = subprocess.run(['git', 'rev-parse', 'HEAD'],
                                check=True, capture_output=True, text=True)
        return result.stdout.strip()
    except (FileNotFoundError, subprocess.CalledProcessError):
        return ''


def git_head_tag():
    """Return the tag exactly at HEAD, or an empty string if there is none."""
    try:
        result = subprocess.run(['git', 'describe', '--tags', '--exact-match', 'HEAD'],
                                check=True, capture_output=True, text=True)
        return result.stdout.strip()
    except (FileNotFoundError, subprocess.CalledProcessError):
        return ''


def git_worktree_is_clean():
    """Return True when tracked files match HEAD."""
    try:
        subprocess.run(['git', 'diff', '--quiet'], check=True)
        subprocess.run(['git', 'diff', '--cached', '--quiet'], check=True)
        return True
    except (FileNotFoundError, subprocess.CalledProcessError):
        return False


def github_version_links(version):
    """Return link names and URLs for the iad and iadplus versions used."""
    base_url = get_github_base_url()
    tag = version_to_tag(version)

    if git_tag_exists(tag) and git_head_tag() == tag and git_worktree_is_clean():
        release_url = base_url + '/releases/tag/' + tag
        return [('iad', release_url), ('iadplus', release_url)]

    commit = git_head_commit()
    if commit:
        source_url = base_url + '/tree/' + commit
    else:
        source_url = base_url

    return [('iad', source_url), ('iadplus', source_url)]


def iadplus_command_line():
    """Return the current iadplus invocation in a reproducible form."""
    return ' '.join(shlex.quote(arg) for arg in ['iadplus'] + sys.argv[1:])


def display_input_path(input_name):
    """Return the user-facing input path without an unnecessary absolute prefix."""
    if os.path.isabs(input_name):
        try:
            return os.path.relpath(input_name, os.getcwd())
        except ValueError:
            return input_name
    return input_name


def iad_command_line(input_name, options):
    """Return the user-facing iad command used for this input."""
    display_name = input_name
    if not os.path.exists(display_name) and not display_name.endswith('.rxt'):
        display_name += '.rxt'

    command = ['./iad']
    if options:
        command.extend(shlex.split(options))
    command.extend(['-J', display_input_path(display_name)])
    return ' '.join(shlex.quote(arg) for arg in command)


