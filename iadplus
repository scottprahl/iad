def latex_artifact_name(name):
    """Return a filename stem that ``pdflatex`` can safely open.

    Args:
        name: Desired artifact stem.

    Returns:
        Sanitized stem containing only simple filename characters.
    """
    safe = name.replace('%', 'pct')
    safe = re.sub(r'[^A-Za-z0-9_.-]+', '_', safe)
