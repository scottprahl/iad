def normalize_output_header_value(value):
    """Normalize values from the generated .txt header."""
    value = value.strip()
    value = value.replace('(varies with input row)', 'varies')
    value = value.replace('varies with input row', 'varies')
    return value


def split_output_header_value(value):
    """Return the table value and any units or notes from a header value."""
    value = normalize_output_header_value(value)
    if not value:
        return '', ''

    match = re.match(r'(\S+)(?:\s+(.*))?$', value)
    if not match:
        return value, ''

    number = match.group(1)
    units = (match.group(2) or '').strip()
    return number, units


def format_output_header_description(description, units):
    """Append units from the value field to the output header description."""
    if not units:
        return description

    note = ''
    match = re.match(r'(.+?)\s+(\(.*\))$', units)
    if match:
        units = match.group(1).strip()
        note = ' ' + match.group(2).strip()

    return '%s [%s]%s' % (description, units, note)


def parse_output_header(output_filename):
    """Parse the generated .txt header through the photons-used line."""
    table_rows = []

    with open(output_filename, 'r', encoding='utf-8') as file:
        for line_number, line in enumerate(file, start=1):
            if line_number <= 2:
                continue

            text = line.lstrip('#').strip()
            if not text:
                continue

            if '=' in text:
                description, value = text.split('=', 1)
                description = description.strip()
                value, units = split_output_header_value(value)
                description = format_output_header_description(description, units)
                table_rows.append((value, description))

                if description.startswith('Photons used'):
                    break
            else:
                table_rows.append(('', text))

    return table_rows


def markdown_escape(text):
    """Escape text for a Markdown table cell."""
    return text.replace('\\', '\\\\').replace('|', '\\|')


def markdown_header_table(output_filename):
    """Return Markdown for the generated output header summary."""
    table_rows = parse_output_header(output_filename)
    lines = []

    if table_rows:
        lines.append('| Number | Description |')
        lines.append('| --- | --- |')
        for value, description in table_rows:
            lines.append('| %s | %s |' %
                         (markdown_escape(value), markdown_escape(description)))
        lines.append('')

    return '\n'.join(lines)


def latex_escape(text):
    """Escape text for normal LaTeX paragraphs."""
    replacements = {
        '\\': r'\textbackslash{}',
        '&': r'\&',
        '%': r'\%',
        '$': r'\$',
        '#': r'\#',
        '_': r'\_',
        '{': r'\{',
        '}': r'\}',
        '~': r'\textasciitilde{}',
        '^': r'\textasciicircum{}',
    }
    return ''.join(replacements.get(char, char) for char in text)


def latex_path(filename):
    """Return a LaTeX-safe path argument."""
    return r'\detokenize{%s}' % filename


def latex_artifact_name(name):
    """Return a filename stem that pdflatex can safely open."""
    safe = name.replace('%', 'pct')
    safe = re.sub(r'[^A-Za-z0-9_.-]+', '_', safe)
    return safe.strip('._') or 'iadplus_report'


def write_latex_header_table(file, output_filename):
    """Write the generated output header summary as LaTeX."""
    table_rows = parse_output_header(output_filename)

    if table_rows:
        file.write(r'\begin{longtable}{|p{15mm}p{0.78\linewidth}|}' + '\n')
        file.write(r'\hline' + '\n')
        for value, description in table_rows:
            if value:
                file.write('%s & %s\\\\\n' %
                           (latex_escape(value), latex_escape(description)))
            else:
                file.write(r'\multicolumn{2}{|p{\dimexpr0.78\linewidth+15mm+2\tabcolsep\relax}|}{}\\[0.5em]' + '\n')
                file.write(r'\multicolumn{2}{|p{\dimexpr0.78\linewidth+15mm+2\tabcolsep\relax}|}{\textit{%s}}\\' %
                           latex_escape(description) + '\n')
        file.write(r'\hline' + '\n')
        file.write(r'\end{longtable}' + '\n\n')


def _numbers_in_row(line):
    """Return numeric values before any inline comment."""
    line = line.split('#', 1)[0]
    values = []
    for token in line.split():
        try:
            values.append(float(token))
        except ValueError:
            return []
    return values


def _read_rxt_column(input_filename, label):
    """Read a labeled numeric column from an IAD .rxt file."""
    label_index = None
    values = []

    with open(input_filename, 'r', encoding='utf-8') as file:
        for line in file:
            stripped = line.strip()
            if not stripped:
                continue

            if label_index is None:
                candidate = stripped.lstrip('#').split('#', 1)[0].split()
                labels = [item.lower() for item in candidate]
                if label in labels:
                    label_index = labels.index(label)
                continue

            row = _numbers_in_row(stripped)
            if row and len(row) > label_index:
                values.append(row[label_index])

    if label_index is None or not values:
        raise ValueError('Could not find column "%s" in %s' % (label, input_filename))

    return np.asarray(values)


def get_thickness(output_filename, input_filename=None):
    """Return the sample thickness from the output header or input rows."""
    pattern = r'Sample thickness\s*=\s*([-+]?(?:\d+\.?\d*|\.\d+)(?:[eE][-+]?\d+)?)'
    with open(output_filename, 'r', encoding='utf-8') as file:
        for line in file:
            match = re.search(pattern, line)
            if match:
                return float(match.group(1))
            if 'Sample thickness' in line and 'varies with input row' in line:
                if input_filename is None:
                    input_filename = os.path.splitext(output_filename)[0] + '.rxt'
                return _read_rxt_column(input_filename, 'd')

    raise ValueError('Could not determine sample thickness from %s' % output_filename)


