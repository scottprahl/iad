def add_x_label(lambda0):
    """Label the current plot's x axis from the first coordinate value.

    Args:
        lambda0: Array-like wavelength or measurement-number coordinates. Values
            above 300 are treated as wavelengths in nanometers.
    """
    if lambda0[0] > 300:
        plt.xlabel('Wavelength (nm)')
    else:
        plt.xlabel('Measurement Number')

def plot_good(x, y, success, big_points=False):
    """Plot successful fit points on the current axes.

    Args:
        x: Array-like x coordinates.
        y: Array-like y coordinates.
        success: Boolean mask selecting successful rows.
        big_points: When true, draw larger hollow markers for overlays.
    """
    if big_points:
        size = 7
        fc = 'none'
    else :
        size = 2
        fc = 'blue'
    if any(success):
        plt.plot(x[success], y[success], marker='o', markersize=size,
                 markerfacecolor=fc, markeredgecolor='blue', linestyle='None',
                 label='fit')
    plt.grid(True)

def plot_good_and_bad(x, y, success, big_points=False):
    """Plot successful and failed fit points on the current axes.

    Args:
        x: Array-like x coordinates.
        y: Array-like y coordinates.
        success: Boolean mask selecting successful rows.
        big_points: When true, draw larger hollow markers for successful rows.
    """
    if big_points:
        size = 7
        fc = 'none'
    else :
        size = 2
        fc = 'blue'
    if any(success):
        plt.plot(x[success], y[success], marker='o', markersize=size,
                 markerfacecolor=fc, markeredgecolor='blue', linestyle='None',
                 label='fit')

    if any(~success):
        plt.plot(x[~success], y[~success], 'xr', label='failed')
        plt.legend()
    plt.grid(True)


def plot_results(results, item, bp, ylabel, figure_ext='.svg'):
    """Plot one result column for all summarized ``iadplus`` outputs.

    Args:
        results: Mapping from display label to parsed result arrays. Each value
            is ordered as ``lam, mr, cr, mt, ct, mua, musp, g, mus, b, a,
            success``.
        item: ``Column`` member selecting the result column and output suffix.
        bp: Output filename base path for the summary artifact.
        ylabel: Y-axis label for the plot.
        figure_ext: Figure extension for the saved plot.

    Returns:
        Basename of the saved figure.
    """
    plt.figure(figsize=(8, 4.5))
    the_column = item.position
    out_filename = bp + item.value.replace('.svg', figure_ext)

    for key in sorted(results.keys()):
        r = results[key]
        success = r[-1]
        lam = r[0]
        y = r[the_column]
        if the_column in [Column.MR.position, Column.MT.position]:
            plt.plot(lam, y, label=key)
        else:
            plt.plot(lam[success], y[success], label=key)

    add_x_label(lam)
    plt.ylabel(ylabel)
    plt.legend()
    plt.savefig(out_filename)
    plt.close()
    return os.path.basename(out_filename)

def append_graph_cell(nb, header, graph):
    """Append a Markdown image cell to a summary notebook.

    Args:
        nb: Notebook object to mutate.
        header: Markdown header text to prepend.
        graph: Figure filename relative to the notebook.
    """
    cell_text = header + "\n"
    url_encoded_filename = urllib.parse.quote(graph)
    cell_text += "<center>\n"
    cell_text += '    <img src="' + url_encoded_filename + '" width="80%" />\n'
    cell_text += "</center>\n"
    nb.cells.append(new_markdown_cell(cell_text))


def append_file_cell(nb, header, file):
    """Append a code cell that prints a sibling text file.

    Args:
        nb: Notebook object to mutate.
        header: Markdown-style comment header for the code cell.
        file: Path to the file whose basename should be opened by the notebook.
    """
    base = os.path.basename(file)
    cell_text = header + '\n'
    cell_text += 'with open("' + base + '", "r", encoding="utf-8") as file:\n'
    cell_text += '    file_contents = file.read()\n'
    cell_text += '\n'
    cell_text += 'print(file_contents)\n'
    nb.cells.append(new_code_cell(cell_text))


