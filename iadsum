def get_github_base_url():
    """Return the GitHub repository URL for this checkout.

    Returns:
        Origin URL normalized to ``https://github.com/...``. Falls back to the
        public ``scottprahl/iad`` URL when git metadata is unavailable.
    """
    try:
        result = subprocess.run(['git', 'remote', 'get-url', 'origin'],
                                check=True, capture_output=True, text=True)
    except (FileNotFoundError, subprocess.CalledProcessError):
        return 'https://github.com/scottprahl/iad'

    url = result.stdout.strip()
    match = re.match(r'git@github\.com:(.+?)(?:\.git)?$', url)
    if match:
        return 'https://github.com/' + match.group(1)

    match = re.match(r'https://github\.com/(.+?)(?:\.git)?$', url)
    if match:
        return 'https://github.com/' + match.group(1)

    return 'https://github.com/scottprahl/iad'


def version_to_tag(version):
    """Convert an ``iad`` version string to a release tag.

    Args:
        version: Version printed by ``iad``, such as ``'3-16-3'``.

    Returns:
        Release tag form, such as ``'v3.16.3'``.
    """
    return 'v' + version.replace('-', '.')


def git_tag_exists(tag):
    """Return whether a release tag exists in the local checkout.

    Args:
        tag: Git tag name to look up.

    Returns:
        True when the tag exists locally, otherwise false.
    """
    try:
        subprocess.run(['git', 'rev-parse', '--verify', '--quiet', 'refs/tags/' + tag],
                       check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except (FileNotFoundError, subprocess.CalledProcessError):
        return False


def git_head_commit():
    """Return the current git commit hash.

    Returns:
        Full ``HEAD`` commit hash, or an empty string when git is unavailable.
    """
    try:
        result = subprocess.run(['git', 'rev-parse', 'HEAD'],
                                check=True, capture_output=True, text=True)
        return result.stdout.strip()
    except (FileNotFoundError, subprocess.CalledProcessError):
        return ''


def git_head_tag():
    """Return the tag exactly at ``HEAD``.

    Returns:
        Exact tag name, or an empty string when ``HEAD`` is not tagged.
    """
    try:
        result = subprocess.run(['git', 'describe', '--tags', '--exact-match', 'HEAD'],
                                check=True, capture_output=True, text=True)
        return result.stdout.strip()
    except (FileNotFoundError, subprocess.CalledProcessError):
        return ''


def git_worktree_is_clean():
    """Return whether tracked files match ``HEAD``.

    Returns:
        True when there are no tracked or staged changes, otherwise false.
    """
    try:
        subprocess.run(['git', 'diff', '--quiet'], check=True)
        subprocess.run(['git', 'diff', '--cached', '--quiet'], check=True)
        return True
    except (FileNotFoundError, subprocess.CalledProcessError):
        return False


def github_version_links(version):
    """Return provenance links for the ``iad`` and ``iadsum`` versions used.

    Args:
        version: Version string parsed from the ``iad`` output header.

    Returns:
        List of ``(name, url)`` tuples. Tagged clean releases link to the release
        page; other checkouts link to the current commit when available.
    """
    base_url = get_github_base_url()
    tag = version_to_tag(version)

    if git_tag_exists(tag) and git_head_tag() == tag and git_worktree_is_clean():
        release_url = base_url + '/releases/tag/' + tag
        return [('iad', release_url), ('iadsum', release_url)]

    commit = git_head_commit()
    if commit:
        source_url = base_url + '/tree/' + commit
    else:
        source_url = base_url

    return [('iad', source_url), ('iadsum', source_url)]


def iadsum_command_line():
    """Return the current ``iadsum`` invocation in reproducible shell form.

    Returns:
        Shell-quoted command line beginning with ``iadsum``.
    """
    return ' '.join(shlex.quote(arg) for arg in ['iadsum'] + sys.argv[1:])


def formatted_today():
    """Return today's date in the report provenance format.

    Returns:
        Date string such as ``'10 May 2026'``.
    """
    today = datetime.today()
    return '%d %s' % (today.day, today.strftime('%b %Y'))


def append_html_graph(file, header, graph):
    """Write one graph section to an HTML summary.

    Args:
        file: Open writable HTML file.
        header: Section heading.
        graph: Figure filename relative to the HTML file.
    """
    file.write('<h2>%s</h2>\n' % html_escape(header))
    file.write('<img src="%s" alt="%s">\n' %
               (urllib.parse.quote(graph), html_escape(header)))


def write_html_summary(html_path, summary_command, version_links,
                       commands, links, graph_items):
    """Write a direct HTML summary report.

    Args:
        html_path: Destination path for the generated HTML file.
        summary_command: Command used to create this summary document.
        version_links: Iterable of ``(name, url)`` provenance links.
        commands: Command lines read from summarized ``iad`` outputs.
        links: Iterable of ``(display_path, href_path)`` report links.
        graph_items: Iterable of ``(header, graph_filename)`` pairs.
    """
    with open(html_path, 'w', encoding='utf-8') as file:
        file.write('<!doctype html>\n<html lang="en">\n<head>\n')
        file.write('<meta charset="utf-8">\n')
        file.write('<title>Summary of Inverse Adding-Doubling Analysis</title>\n')
        file.write('<style>\n')
        file.write('body{font-family:Arial,sans-serif;line-height:1.5;margin:2rem auto;max-width:980px;color:#222;}\n')
        file.write('h1,h2{line-height:1.2;} img{max-width:100%;height:auto;display:block;margin:1rem auto;}\n')
        file.write('pre{background:#f6f6f6;border:1px solid #ddd;padding:1rem;overflow:auto;}\n')
        file.write('</style>\n</head>\n<body>\n')
        file.write('<h1>Summary of Inverse Adding-Doubling Analysis</h1>\n')
        file.write('<p>Created on %s</p>\n' % html_escape(formatted_today()))
        file.write('<p>The commands used to create this document were</p>\n')
        file.write('<pre>%s</pre>\n' % html_escape(summary_command))
        file.write('<h2>Software version used</h2>\n<ul>\n')
        for name, url in version_links:
            file.write('<li>%s: <a href="%s">%s</a></li>\n' %
                       (html_escape(name), html_escape(url), html_escape(url)))
        file.write('</ul>\n')
        file.write('<h2>Commands used for summarized files</h2>\n<pre>%s</pre>\n' %
                   html_escape(''.join(commands)))
        if links:
            file.write('<h2>Summarized reports</h2>\n<ul>\n')
            for display_path, href_path in links:
                quoted = urllib.parse.quote(href_path)
                file.write('<li><a href="%s">%s</a></li>\n' %
                           (quoted, html_escape(display_path)))
            file.write('</ul>\n')
        for header, graph in graph_items:
            append_html_graph(file, header, graph)
        file.write('</body>\n</html>\n')


def latex_escape(text):
    """Escape text for normal LaTeX paragraphs.

    Args:
        text: Plain text that may contain LaTeX metacharacters.

    Returns:
        Text with LaTeX metacharacters escaped.
    """
    replacements = {
        '\\': r'\textbackslash{}',
        '&': r'\&',
        '%': r'\%',
        '$': r'\$',
        '#': r'\#',
        '_': r'\_',
        '{': r'\{',
        '}': r'\}',
        '~': r'\textasciitilde{}',
        '^': r'\textasciicircum{}',
    }
    return ''.join(replacements.get(char, char) for char in str(text))


def latex_path(filename):
    """Return a LaTeX-safe path argument.

    Args:
        filename: Path to include in a LaTeX command.

    Returns:
        A ``\\detokenize{...}`` wrapper around the path.
    """
    return r'\detokenize{%s}' % filename


def latex_url(url):
    """Return a clickable LaTeX URL.

    Args:
        url: URL to include in a PDF report.

    Returns:
        A ``\\url{...}`` command using ``\\detokenize`` for robust URL text.
    """
    return r'\url{%s}' % latex_path(url)


def write_pdf_summary(pdf_path, summary_command, version_links,
                      commands, links, graph_groups, summary_dir):
    """Write a PDF summary that includes Matplotlib-generated PDF plots.

    Args:
        pdf_path: Destination path for the generated PDF file.
        summary_command: Command used to create this summary document.
        version_links: Iterable of ``(name, url)`` provenance links.
        commands: Command lines read from summarized ``iad`` outputs.
        links: Iterable of ``(display_path, href_path)`` report links.
        graph_groups: Ordered graph groups. Each group contains one or two
            ``(header, graph_filename)`` pairs.
        summary_dir: Directory containing the generated graph PDFs.
    """
    tex_path = os.path.splitext(pdf_path)[0] + '.tex'
    with open(tex_path, 'w', encoding='utf-8') as file:
        file.write(r'\documentclass[11pt]{article}' + '\n')
        file.write(r'\usepackage[margin=1in]{geometry}' + '\n')
        file.write(r'\usepackage{graphicx}' + '\n')
        file.write(r'\usepackage{float}' + '\n')
        file.write(r'\usepackage{fancyvrb}' + '\n')
        file.write(r'\usepackage{titlesec}' + '\n')
        file.write(r'\usepackage[colorlinks=true,urlcolor=blue]{hyperref}' + '\n')
        file.write(r'\setlength{\parindent}{0pt}' + '\n')
        file.write(r'\setlength{\parskip}{0.8em}' + '\n')
        file.write(r'\titlespacing*{\section}{0pt}{0.6em}{0.2em}' + '\n')
        file.write(r'\begin{document}' + '\n')
        file.write(r'\section*{Summary of Inverse Adding-Doubling Analysis}' + '\n')
        file.write('Created on %s\n\n' % latex_escape(formatted_today()))
        file.write('The commands used to create this document were\n\n')
        file.write(r'\texttt{%s}' % latex_escape(summary_command) + '\n\n')
        file.write('Software version used:\n\n')
        for name, url in version_links:
            file.write('%s: %s' % (latex_escape(name), latex_url(url)) + r'\\' + '\n')
        file.write('\nCommand lines used for summarized files:\n\n')
        file.write(r'\begin{Verbatim}[fontsize=\small]' + '\n')
        file.write(''.join(commands) if commands else 'No commands found.\n')
        file.write(r'\end{Verbatim}' + '\n')
        if links:
            file.write('Summarized reports:\n\n')
            file.write(r'\begin{itemize}' + '\n')
            for display_path, _ in links:
                file.write(r'\item %s' % latex_escape(display_path) + '\n')
            file.write(r'\end{itemize}' + '\n')
        file.write(r'\clearpage' + '\n\n')

        for index, graph_group in enumerate(graph_groups):
            max_height = r'0.78\textheight' if len(graph_group) == 1 else r'0.42\textheight'
            for header, graph in graph_group:
                file.write(r'\section*{%s}' % latex_escape(header) + '\n')
                file.write(r'\begin{figure}[H]' + '\n')
                file.write(r'\centering' + '\n')
                file.write(r'\includegraphics[width=\linewidth,height=%s,keepaspectratio]{%s}' %
                           (max_height, latex_path(graph)) + '\n')
                file.write(r'\end{figure}' + '\n\n')
            if index < len(graph_groups) - 1:
                file.write(r'\clearpage' + '\n\n')

        file.write(r'\end{document}' + '\n')

    command = ['pdflatex', '-interaction=batchmode', os.path.basename(tex_path)]
    print('running:', ' '.join(command), flush=True)
    try:
        subprocess.run(command, cwd=summary_dir, check=True,
                       stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                       text=True)
    except subprocess.CalledProcessError as error:
        log_path = os.path.splitext(tex_path)[0] + '.log'
        if os.path.exists(log_path):
            with open(log_path, 'r', encoding='utf-8', errors='replace') as log_file:
                lines = log_file.readlines()
            print(''.join(lines[-80:]))
        elif error.stdout:
            print(error.stdout)
        raise


def _numbers_in_row(line):
    """Return numeric values before any inline comment.

    Args:
        line: Input line from an ``.rxt`` file.

    Returns:
        List of floating-point values, or an empty list when a token is not
        numeric.
    """
    line = line.split('#', 1)[0]
    values = []
    for token in line.split():
        try:
            values.append(float(token))
        except ValueError:
            return []
    return values


def _read_rxt_column(input_filename, label):
    """Read a labeled numeric column from an ``iad`` ``.rxt`` file.

    Args:
        input_filename: Path to the ``.rxt`` file.
        label: Lowercase column label to find.

    Returns:
        NumPy array containing the column values.

    Raises:
        ValueError: If the label or any values cannot be found.
    """
    label_index = None
    values = []

    with open(input_filename, 'r', encoding='utf-8') as file:
        for line in file:
            stripped = line.strip()
            if not stripped:
                continue

            if label_index is None:
                candidate = stripped.lstrip('#').split('#', 1)[0].split()
                labels = [item.lower() for item in candidate]
                if label in labels:
                    label_index = labels.index(label)
                continue

            row = _numbers_in_row(stripped)
            if row and len(row) > label_index:
                values.append(row[label_index])

    if label_index is None or not values:
        raise ValueError('Could not find column "%s" in %s' % (label, input_filename))

    return np.asarray(values)


def get_thickness(output_filename, input_filename=None):
    """Return sample thickness from an output header or input rows.

    Args:
        output_filename: Path to the generated ``.txt`` output file.
        input_filename: Optional path to the source ``.rxt`` file. Used when the
            output header says thickness varies by input row.

    Returns:
        Scalar thickness value, or an array of row-specific values when the
        source file contains a thickness column.

    Raises:
        ValueError: If thickness cannot be determined.
    """
    pattern = r'Sample thickness\s*=\s*([-+]?(?:\d+\.?\d*|\.\d+)(?:[eE][-+]?\d+)?)'
    with open(output_filename, 'r', encoding='utf-8') as file:
        for line in file:
            match = re.search(pattern, line)
            if match:
                return float(match.group(1))
            if 'Sample thickness' in line and 'varies with input row' in line:
                if input_filename is None:
                    input_filename = os.path.splitext(output_filename)[0] + '.rxt'
                return _read_rxt_column(input_filename, 'd')

    raise ValueError('Could not determine sample thickness from %s' % output_filename)


def summary_metadata(txts, report_links):
    """Collect command provenance and report links for a summary.

    Args:
        txts: Absolute paths to the ``iad`` output files being summarized.
        report_links: Iterable of ``(display_path, href_path)`` report links.

    Returns:
        A ``(commands, report_links, version, build)`` tuple.

    Raises:
        ValueError: If an output file does not contain the expected version
            header.
    """
    # Inverse Adding-Doubling 3-15-2 (8 Mar 2024)
    # iad -M 0 -o /Users/prahl/Documents/Code/git/iad/test/basic_B.txt test/basic_B.rxt

    commands = []
    first_line = ''
    for txt in txts:
        with open(txt, 'r', encoding='utf-8') as file:
            first_line = file.readline()
            second_line = file.readline()
            cmd = re.sub(r'^# ', '', second_line)
            commands.append('    ' + cmd + '\n')

    pattern = r'(\d+-\d+-\d+) \((\d+ \w+ \d+)\)'
    match = re.search(pattern, first_line)
    if not match:
        raise ValueError('File %s contains bad contents' % txts[0])
    version = match.group(1)
    build = match.group(2)
    return commands, report_links, version, build


def append_header(nb, commands, links, summary_command, version_links):
    """Append a summary header cell with command provenance.

    Args:
        nb: Notebook object to mutate.
        commands: Command lines read from summarized ``iad`` outputs.
        links: Iterable of ``(display_path, href_path)`` report links.
        summary_command: Command used to create this summary document.
        version_links: Iterable of ``(name, url)`` provenance links.
    """
    cell_text = "# Summary of Inverse Adding-Doubling Analysis\n\n"
    cell_text += "Created on %s\n\n" % formatted_today()
    cell_text += "The commands used to create this document were\n\n"
    cell_text += "`%s`\n\n" % summary_command
    cell_text += "Software version used:\n\n"
    for name, url in version_links:
        cell_text += "- %s: [%s](%s)\n\n" % (name, url, url)

    cell_text += "The command line used for each summarized file:\n"
    for c in commands:
        cell_text += c

    cell_text += "Links to summarized reports:\n"
    for display_path, href_path in links:
        quoted = urllib.parse.quote(href_path)
        cell_text += "\n* [%s](%s)\n" % (display_path, quoted)

    nb.cells.append(new_markdown_cell(cell_text))

def create_summary_directory(directory):
    """Create the summary notebook directory.

    Args:
        directory: Root directory being summarized.

    Returns:
        Base path for summary artifacts, without extension.
    """
    base='summary'
    notebook_dir = os.path.join(directory, base)

    if not os.path.exists(notebook_dir):
        os.makedirs(notebook_dir)

    return os.path.join(notebook_dir, base)


def find_reports_in_dir(directory):
    """Find ``iadplus`` reports below a directory.

    Args:
        directory: Directory tree to search.

    Returns:
        List of report paths, excluding checkpoint and summary directories.
    """
    report_paths = []
    for root, dirs, files in os.walk(directory):
        if '.ipynb_checkpoints' in dirs:
            dirs.remove('.ipynb_checkpoints')  # Skip .ipynb_checkpoints directory
        if 'summary' in dirs:
            dirs.remove('summary')  # Skip summary directory
        for file in files:
            ext = os.path.splitext(file)[1].lower()
            stem = os.path.splitext(file)[0]
            if ext in REPORT_EXTENSIONS and not stem.endswith(PLOT_SUFFIXES):
                report_paths.append(os.path.join(root, file))
    return report_paths


def report_output_mode(report_paths):
    """Infer the summary output mode from discovered report extensions.

    Args:
        report_paths: Paths to discovered ``iadplus`` reports.

    Returns:
        One of ``'notebook'``, ``'html'``, or ``'pdf'``.
    """
    counts = {'notebook': 0, 'html': 0, 'pdf': 0}
    for path in report_paths:
        ext = os.path.splitext(path)[1].lower()
        counts[REPORT_EXTENSIONS[ext]] += 1

    # Tie-break in favor of richer editable formats.
    return max(['notebook', 'html', 'pdf'], key=lambda mode: (counts[mode], -['notebook', 'html', 'pdf'].index(mode)))


def txt_for_report(report_path):
    """Return the sibling ``.txt`` output path for an ``iadplus`` report.

    Args:
        report_path: Path to a discovered ``.ipynb``, ``.html``, or ``.pdf``
            report.

    Returns:
        Matching ``.txt`` path, or an empty string when no unambiguous sibling
        exists.
    """
    stem_txt = os.path.splitext(report_path)[0] + '.txt'
    if os.path.exists(stem_txt):
        return stem_txt

    directory = os.path.dirname(report_path)
    txts = [os.path.join(directory, item) for item in os.listdir(directory)
            if item.endswith('.txt')]
    if len(txts) == 1:
        return txts[0]
    return ''

def read_txt(txt_path):
    """Read an ``iad`` output file and derive additional optical properties.

    Args:
        txt_path: Path to an ``iad`` ``.txt`` output file.

    Returns:
        List ordered as ``lam, mr, cr, mt, ct, mua, musp, g, mus, b, a,
        success``. ``success`` is a boolean mask derived from the status column.
    """
    result = np.loadtxt(txt_path, skiprows=44, usecols=range(8), delimiter='\t')
    lam, mr, cr, mt, ct, mua, musp, g = result.T
    lam = np.atleast_1d(lam)
    mr = np.atleast_1d(mr)
    cr = np.atleast_1d(cr)
    mt = np.atleast_1d(mt)
    ct = np.atleast_1d(ct)
    mua = np.atleast_1d(mua)
    musp = np.atleast_1d(musp)
    g = np.atleast_1d(g)

    converters = {8: lambda s: s.lstrip('#').strip()}
    status = np.loadtxt(txt_path, usecols=[8], dtype=str, converters=converters)
    status = np.atleast_1d(status)
    success = status == '*'

    d = get_thickness(txt_path)
    mus = musp/(1-g)
    b = (mua + mus)*d

    denominator = mua + mus
    safe_denominator = np.where(denominator == 0, np.inf, denominator)
    a = mus / safe_denominator

    return [lam, mr,cr,mt,ct,mua,musp,g,mus,b,a,success]

def get_directory_list(path):
    """Split a path into all directory components.

    Args:
        path: Path to split.

    Returns:
        List of path components from root to leaf.
    """
    directories = []
    while True:
        path, directory = os.path.split(path)
        if directory != "":
            directories.append(directory)
        else:
            if path != "":
                directories.append(path)
            break
    return list(reversed(directories))

def main():
    """Run the ``iadsum`` command-line interface.

    Searches for ``iadplus`` reports, reads their sibling ``.txt`` files,
    generates overlaid comparison plots, and writes a summary report matching
    the discovered report type unless explicitly overridden.
    """
    desc =  'Create a summary report from iadplus reports and their iad '
    desc += 'output files. The output format defaults to the report type found.'
    parser = argparse.ArgumentParser(description=desc)
    parser.add_argument('directory', metavar='DIRECTORY',
                        help='single directory path')
    output_group = parser.add_mutually_exclusive_group()
    output_group.add_argument('--pdf', dest='output_mode', action='store_const', const='pdf',
                              help='create a PDF summary')
    output_group.add_argument('--notebook', dest='output_mode', action='store_const',
                              const='notebook',
                              help='create a Jupyter notebook summary')
    output_group.add_argument('--html', dest='output_mode', action='store_const', const='html',
                              help='create an HTML summary')
    parser.set_defaults(output_mode=None)
    args = parser.parse_args()

    abs_dir = os.path.abspath(args.directory)
    abs_reports = find_reports_in_dir(abs_dir)
    if not abs_reports:
        print('no iadplus reports found in "%s"' % args.directory)
        return

    output_mode = args.output_mode or report_output_mode(abs_reports)
    print('looking in "%s" for iadplus reports' % args.directory)
    print('creating %s summary' % output_mode)

    report_txt_pairs = []
    seen_txts = set()
    for report_path in abs_reports:
        txt_path = txt_for_report(report_path)
        if txt_path and os.path.exists(txt_path) and os.path.getsize(txt_path) > 0:
            if txt_path not in seen_txts:
                report_txt_pairs.append((report_path, txt_path))
                seen_txts.add(txt_path)
        else:
            print('skipping %s: no matching .txt output' % report_path)

    if not report_txt_pairs:
        print('no readable iad .txt outputs found in "%s"' % args.directory)
        return

    abs_txts = [txt for _, txt in report_txt_pairs]
    bp = create_summary_directory(args.directory)
    summary_dir = os.path.dirname(bp)
    report_links = [
        (os.path.relpath(report, os.getcwd()), os.path.relpath(report, summary_dir))
        for report, _ in report_txt_pairs
    ]

    results={}
    for _, txt_path in report_txt_pairs:
        print('reading ', os.path.relpath(txt_path, os.getcwd()))
        key = get_directory_list(txt_path)[-2]
        results[key] = read_txt(txt_path)

    figure_ext = '.pdf' if output_mode == 'pdf' else '.svg'
    r_graph = plot_results(results, Column.MR, bp, 'M_R', figure_ext)
    t_graph = plot_results(results, Column.MT, bp, 'M_T', figure_ext)
    mus_graph = plot_results(results, Column.MUS, bp, 'Scattering Coefficient (mm⁻¹)',
                             figure_ext)
    musp_graph = plot_results(results, Column.MUSP, bp,
                              'Reduced Scattering Coefficient (mm⁻¹)', figure_ext)
    mua_graph = plot_results(results, Column.MUA, bp, 'Absorption Coefficient (mm⁻¹)',
                             figure_ext)
    g_graph = plot_results(results, Column.G, bp, 'Scattering Anisotropy', figure_ext)
    a_graph = plot_results(results, Column.A, bp,
                           r'Single Scattering Albedo $\mu_s/(\mu_a+\mu_s)$',
                           figure_ext)
    b_graph = plot_results(results, Column.B, bp, r'Optical Thickness $(\mu_a+\mu_s)d$',
                           figure_ext)

    graph_groups = [
        [('Reflection', r_graph), ('Transmission', t_graph)],
        [('Scattering Coefficient', mus_graph),
         ('Reduced Scattering Coefficient', musp_graph)],
        [('Absorption Coefficient', mua_graph),
         ('Scattering Anisotropy', g_graph)],
        [('Single Scattering Albedo', a_graph), ('Optical Thickness', b_graph)],
    ]
    graph_items = [item for group in graph_groups for item in group]

    commands, links, version, _ = summary_metadata(abs_txts, report_links)
    summary_command = iadsum_command_line()
    version_links = github_version_links(version)

    if output_mode == 'notebook':
        nb = new_notebook()
        nb.metadata['kernelspec'] = {
            'display_name': 'Python 3',
            'language': 'python',
            'name': 'python3'
        }

        append_header(nb, commands, links, summary_command, version_links)
        for header, graph in graph_items:
            append_graph_cell(nb, '## ' + header, graph)

        output_path = bp + '.ipynb'
        with open(output_path, "w", encoding="utf-8") as f:
            nbformat.write(nb, f)
    elif output_mode == 'html':
        output_path = bp + '.html'
        write_html_summary(output_path, summary_command, version_links,
                           commands, links, graph_items)
    else:
        output_path = bp + '.pdf'
        write_pdf_summary(output_path, summary_command, version_links,
                          commands, links, graph_groups, summary_dir)

    print('created: ' + os.path.abspath(output_path))

if __name__ == "__main__":
    main()
